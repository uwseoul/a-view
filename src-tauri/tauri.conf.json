{
  "$schema": "https://v2.tauri.app/schema/tauri.conf.json",
  "productName": "OpenCode Ops Dashboard",
  "version": "1.0.0",
  "identifier": "com.opencode.ops-dashboard",
  "build": {
    "frontendDist": "../public",
    "devUrl": "http://localhost:4317"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "OpenCode Ops Dashboard",
        "width": 1200,
        "height": 800,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
